vars: @./_palette

direction: right

brainstorm
plan
execute
document
review
done {shape: oval}

blocked
failed

cancelled: |md
  any non-terminal\
  → cancelled
| {shape: callout}

force: |md
  any → any\
  via --force
| {shape: callout}

# Happy path
brainstorm -> plan
plan -> execute
execute -> document
document -> review
review -> done

# Fast-close (HATS-371): brainstorm | plan -> done with --resolution
brainstorm -> done: close
plan -> done: close

# Blocked sidetrack
brainstorm -> blocked
plan -> blocked
execute -> blocked
document -> blocked
blocked -> plan: resume
blocked -> execute: resume

# Failure & retry
execute -> failed
review -> failed
failed -> brainstorm: retry

# Rework (HATS-1052): review WITH comments → execute, no worktree merge
review -> execute: rework

# Reopen
done -> execute: reopen
