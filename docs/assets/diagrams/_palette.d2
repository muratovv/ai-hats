# Shared brand-light palette. Each diagram does:
#   vars: { d2-config: @./_palette }
# at the top to inherit the theme-overrides below.
d2-config: {
  theme-id: 0
  theme-overrides: {
    N1: "#0f1a2e"
    N2: "#1c2942"
    N3: "#3a4868"
    N4: "#a2acbf"
    N5: "#d4d9e4"
    N6: "#ebeef4"
    N7: "#faf2e6"
    B1: "#1c2942"
    B2: "#2a3a5c"
    B3: "#3a4f7a"
    B4: "#5a6f9a"
    B5: "#8a9abc"
    B6: "#bac4d8"
    AA2: "#fcd8c2"
    AA4: "#e8632b"
    AA5: "#b54818"
    AB4: "#f5e8d0"
    AB5: "#c9bba0"
  }
}
