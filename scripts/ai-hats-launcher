#!/usr/bin/env bash
# ai-hats launcher — universal host-level entry-point (HATS-339).
#
# Installed once per host at ~/.local/bin/ai-hats by scripts/install-launcher.sh.
# Resolves the project venv (AI_HATS_VENV env > ai-hats.yaml venv_path >
# default <pwd>/.agent/ai-hats/.venv), heals the default venv if it's
# missing/broken, then exec's into <venv>/bin/python -m ai_hats. Self update
# flows through the same path: heal-if-needed → delegate to python ai-hats
# (which renders the rich diff + auto-bumps).
#
# HATS-790 (Alt 5): there is no <venv>/bin/ai-hats console script — the
# [project.scripts] generator was removed so no venv materialises a binary
# that direnv could prepend ahead of this host launcher and run stale code.
# The package is always invoked via `python -m ai_hats`, and venv usability is
# probed via `bin/python` + a deep import probe (HATS-895) rather than the proxy.
set -euo pipefail

PROJECT="$(pwd)"
# HATS-766: anonymous git+https default (override still accepts ssh/local).
REPO_URL="${AI_HATS_REPO_URL:-git+https://github.com/muratovv/ai-hats.git}"
AH_DIR="$PROJECT/.agent/ai-hats"
DEFAULT_VENV="$AH_DIR/.venv"
VERSIONS_DIR="$AH_DIR/versions"   # HATS-647: blue-green versioned venvs

# pip install target — PEP 508 `name @ url` requires a URL scheme. For local
# directory paths we pass the path directly (pip detects pyproject.toml).
# Detection: presence of `://` signals a URL; anything else is treated as a
# local path or already a pip-acceptable spec.
if [[ "$REPO_URL" == *"://"* ]]; then
    PIP_TARGET="ai-hats @ $REPO_URL"
else
    PIP_TARGET="$REPO_URL"
fi

# --- HATS-766: channel-aware heal source ---
# Read the nested harness.channel / harness.path so a `channel: local` project
# heals EDITABLE (see heal_if_needed). Bounded reader for the indented `harness:`
# block, reusing the venv_path strip chain (comments/quotes/tilde).
read_harness_key() {
    local key="$1"
    [[ -f "$PROJECT/ai-hats.yaml" ]] || return 0
    awk '
        /^[^[:space:]]/ { inblock = ($0 ~ /^harness:[[:space:]]*$/) ? 1 : 0; next }
        inblock { print }
    ' "$PROJECT/ai-hats.yaml" \
        | grep -E "^[[:space:]]+${key}:[[:space:]]" \
        | head -1 \
        | sed -E "s/^[[:space:]]+${key}:[[:space:]]+//; s/[[:space:]]+#.*//; s/^\"//; s/\"\$//; s/^'//; s/'\$//" \
        || true
}

HARNESS_CHANNEL="$(read_harness_key channel)"
# Editable source for channel:local (default project root, resolved like venv_path).
LOCAL_SRC=""
if [[ "$HARNESS_CHANNEL" == "local" ]]; then
    LOCAL_SRC="$(read_harness_key path)"
    LOCAL_SRC="${LOCAL_SRC:-.}"
    LOCAL_SRC="${LOCAL_SRC/#\~/$HOME}"
    [[ "${LOCAL_SRC:0:1}" != "/" ]] && LOCAL_SRC="$PROJECT/$LOCAL_SRC"
fi

# --- HATS-944: pin-scope guard mirroring HATS-897. An inherited AI_HATS_VENV
# paired with an AI_HATS_PROJECT_DIR that resolves to a *different* project is a
# leaked session pin (an agent shell cd'd into another project) — honoring it
# would run this project's commands (incl. self update heal/reinstall) against
# the wrong venv. Ignore + warn, then re-resolve below. A bare AI_HATS_VENV with
# no pair keeps historical env-wins semantics (explicit user override).
inherited_venv="${AI_HATS_VENV:-}"
if [[ -n "${AI_HATS_PROJECT_DIR:-}" ]]; then
    pin_proj="${AI_HATS_PROJECT_DIR/#\~/$HOME}"
    pin_real="$(cd "$pin_proj" 2>/dev/null && pwd -P || echo "$pin_proj")"
    if [[ "$pin_real" != "$(pwd -P)" ]]; then
        if [[ -n "$inherited_venv" ]]; then
            echo "ai-hats: AI_HATS_VENV=$inherited_venv is pinned to project $pin_proj — foreign to $PROJECT; ignoring the leaked session pin." >&2
            inherited_venv=""
        fi
        # HATS-1123: AI_HATS_DIR and AI_HATS_PROJECT_DIR must move together. We
        # re-pin AI_HATS_PROJECT_DIR to $PROJECT below; keeping an inherited
        # AI_HATS_DIR aimed at the previous project would make this project's
        # commands (migrations, hook materialization) write into THAT one.
        if [[ -n "${AI_HATS_DIR:-}" ]]; then
            echo "ai-hats: AI_HATS_DIR=$AI_HATS_DIR is pinned to project $pin_proj — foreign to $PROJECT; dropping it." >&2
            unset AI_HATS_DIR
        fi
    fi
fi

# --- Resolve venv (mirrors paths.venv_path precedence) ---
VENV=""
if [[ -n "$inherited_venv" ]]; then
    VENV="${inherited_venv/#\~/$HOME}"
elif [[ -f "$PROJECT/ai-hats.yaml" ]]; then
    # Single-line scalar grep: `venv_path: <value>` (no multi-line / no
    # nested support — out of scope per HATS-339).
    val=$(grep -E '^venv_path:[[:space:]]' "$PROJECT/ai-hats.yaml" 2>/dev/null \
        | head -1 \
        | sed -E 's/^venv_path:[[:space:]]+//; s/[[:space:]]+#.*//; s/^"//; s/"$//; s/^'\''//; s/'\''$//' \
        || true)
    if [[ -n "$val" ]]; then
        val="${val/#\~/$HOME}"
        if [[ "${val:0:1}" == "/" ]]; then
            VENV="$val"
        else
            VENV="$PROJECT/$val"
        fi
    fi
fi
# HATS-647: managed blue-green resolution. When neither an explicit
# AI_HATS_VENV nor a yaml venv_path was set, prefer a valid versions/current
# pointer (a single line of text holding the active sha); else the legacy
# default .venv (lazy migration — pre-versioning installs keep working until
# the first managed `self update` populates versions/).
if [[ -z "$VENV" && -f "$VERSIONS_DIR/current" ]]; then
    # First line only + strip surrounding whitespace (matches paths.read_current_sha;
    # never squash a multi-line file into a fake single sha).
    sha="$(head -1 "$VERSIONS_DIR/current" 2>/dev/null | tr -d '[:space:]' || true)"
    # Require a USABLE versioned venv. HATS-790 (Alt 5): there is no bin/ai-hats
    # console script anymore, so usability keys on bin/python being executable —
    # the launcher execs `bin/python -m ai_hats`, so a runnable interpreter is the
    # signal that the venv can actually run (a complete install is importable when
    # its interpreter is live). A present-but-broken versions/<sha>/ (e.g. a host
    # python upgrade dangling bin/python) is -x-False and falls through to the
    # legacy default .venv rather than dead-ending, preserving self-heal: that
    # broken venv routes to .venv, which heal recreates, and the managed self
    # update then rebuilds versions/<sha>. (heal_if_needed would otherwise refuse
    # a broken non-default venv as user-owned.)
    if [[ -n "$sha" && "$sha" != *"/"* && "$sha" != "." && "$sha" != ".." \
          && -x "$VERSIONS_DIR/$sha/bin/python" ]]; then
        VENV="$VERSIONS_DIR/$sha"
    fi
fi
[[ -z "$VENV" ]] && VENV="$DEFAULT_VENV"

# HATS-647: pin-at-spawn. Export the resolved venv so every descendant
# (hooks, sub-agent child sessions, bash-chained `ai-hats … | ai-hats …`)
# stays on this exact venv for the whole run — even if versions/current
# flips mid-run. A child launcher sees AI_HATS_VENV set and honors it
# verbatim instead of re-resolving the pointer.
export AI_HATS_VENV="$VENV"
# HATS-944: pin the project alongside the venv so the pair is self-describing —
# a launcher→launcher chain (no Python session to set it) still scopes the pin,
# and the guard above can reject it when a descendant cd's into another project.
export AI_HATS_PROJECT_DIR="$PROJECT"

is_default_venv() { [[ "$VENV" == "$DEFAULT_VENV" || "$VENV" == "$VERSIONS_DIR/"* ]]; }

# --- HATS-895: deep venv health probe. Bare `import ai_hats` passes on a venv
# whose editable link moved ahead of its installed deps (a new workspace
# package merged into the dev repo but never installed here) — the CLI then
# dies on ModuleNotFoundError at every call, including the `self update` that
# would fix it. Probe the real entry path plus, for channel:local, every
# source-side packages/* member (editable dist metadata is frozen at install
# time, so the dev repo's tree — not Requires-Dist — is the truth).
# HATS-966: the SAME probe interpreter also flags any provider entry point whose
# module no longer resolves (a stale surface-plugin editable — e.g. a torn-down
# worktree). Printed space-separated to stdout as a SIDE channel and captured into
# PROBE_BROKEN_PLUGINS; the detection is try/except-wrapped so the exit code still
# means ONLY "is the core importable" — a stale plugin never trips the core
# venv-nuke / refuse paths (surfaces aren't in $mods; review B2). Zero extra
# interpreter startups on a healthy launch.
PROBE_REASON=""
PROBE_BROKEN_PLUGINS=""
probe_imports() {
    PROBE_REASON=""
    PROBE_BROKEN_PLUGINS=""
    if [[ ! -x "$VENV/bin/python" ]]; then
        PROBE_REASON="interpreter missing at $VENV/bin/python"
        return 1
    fi
    local mods="ai_hats.cli" init out rc
    if [[ -n "$LOCAL_SRC" ]]; then
        for init in "$LOCAL_SRC"/packages/*/src/*/__init__.py; do
            [[ -e "$init" ]] || continue
            mods+=", $(basename "$(dirname "$init")")"
        done
    fi
    out="$("$VENV/bin/python" -c "
import sys
mods_str = '$mods'
for m in [x.strip() for x in mods_str.split(',') if x.strip()]:
    try:
        __import__(m)
    except Exception as e:
        sys.stderr.write(f'failed importing {m}: {e}\n')
        sys.exit(1)
try:
    import importlib.util
    from importlib.metadata import entry_points
    _b = []
    # Single quotes only — this whole program is a bash double-quoted string,
    # so any double quote here is eaten before python sees it (HATS-595).
    def _is_fp(_ep):
        _d = getattr(_ep, 'dist', None)
        _n = getattr(_d, 'name', None) if _d else None
        if not _n and hasattr(_d, 'metadata') and _d.metadata:
            _n = _d.metadata.get('Name')
        return bool(_n) and _n.replace('_', '-').lower() == 'ai-hats'
    for _ep in entry_points(group='ai_hats.providers'):
        _m = _ep.value.split(':', 1)[0].split('.', 1)[0].strip()
        try:
            _ep.load()
        except AttributeError:
            continue
        except Exception as _exc:
            if _is_fp(_ep):
                sys.stderr.write(f'failed loading entry point {_ep.name!r} ({_ep.value}): {_exc}\n')
                sys.exit(1)
            _b.append(_m)
    if _b:
        print(' '.join(sorted(set(_b))))
except SystemExit:
    raise
except Exception:
    pass
" 2>&1)"
    rc=$?
    if [[ $rc -ne 0 ]]; then
        local err_line
        err_line="$(echo "$out" | tail -n 1)"
        PROBE_REASON="${err_line:-python import probe failed}"
        return $rc
    fi
    PROBE_BROKEN_PLUGINS="$out"
    return 0
}

# --- HATS-938: editable host source for `self init`. Printed to stdout (empty
#     if none), exported as AI_HATS_INIT_SRC so a fresh project auto-seeds
#     harness.channel:local without a manual yaml edit. Detection, in order:
#       1. the resolved venv is an editable install → its PEP 610 file:// path
#          (covers AI_HATS_VENV → editable dev clone, the common dev case);
#       2. the install source is a local directory (channel:local path, or a
#          local AI_HATS_REPO_URL) → that dir.
#     Fail-open: any probe error yields empty (init falls back to STABLE).
detect_init_src() {
    if [[ -x "$VENV/bin/python" ]]; then
        local src
        src="$("$VENV/bin/python" -c '
import json
from importlib.metadata import distribution
try:
    raw = distribution("ai-hats").read_text("direct_url.json") or "{}"
    info = json.loads(raw)
except Exception:
    info = {}
u = info.get("url") or ""
print(u[7:] if (info.get("dir_info") or {}).get("editable") and u.startswith("file://") else "")
' 2>/dev/null || true)"
        if [[ -n "$src" ]]; then printf '%s' "$src"; return 0; fi
    fi
    if [[ -n "$LOCAL_SRC" && -d "$LOCAL_SRC" ]]; then printf '%s' "$LOCAL_SRC"; return 0; fi
    if [[ "$REPO_URL" != *"://"* && -d "$REPO_URL" ]]; then printf '%s' "$REPO_URL"; return 0; fi
    return 0
}

# --- Idempotent heal: no-op if healthy, recreate if default broken,
#     refuse if override broken (user-owned). Called from `self update`
#     and `self init` before delegating, so the user only ever needs one
#     command for install + heal + (update|init). (HATS-337, HATS-612)
heal_if_needed() {
    # HATS-790: no console script to test — a runnable interpreter passing the
    # deep import probe (HATS-895) is the signal the venv can actually run.
    if probe_imports; then
        return 0
    fi
    if ! is_default_venv; then
        echo "ai-hats: override venv $VENV is missing or broken ($PROBE_REASON)." >&2
        echo "  Override venv is user-owned; ai-hats will not auto-recreate it." >&2
        if [[ "$HARNESS_CHANNEL" == "local" ]]; then
            echo "  Fix manually:  uv venv --python 3.11 $VENV && uv pip install --python $VENV/bin/python -e '$LOCAL_SRC'" >&2
        else
            echo "  Fix manually:  uv venv --python 3.11 $VENV && uv pip install --python $VENV/bin/python '$PIP_TARGET'" >&2
        fi
        exit 1
    fi
    echo "  · ai-hats venv missing or broken ($PROBE_REASON) — recreating $VENV" >&2
    # Host-global launcher never auto-installs uv (that's bootstrap.sh's job) — fail loud.
    if ! command -v uv >/dev/null 2>&1; then
        echo "ai-hats: uv is required but not found on PATH." >&2
        echo "  Install: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
        echo "  then re-run. (uv is the single host prerequisite.)" >&2
        exit 1
    fi
    rm -rf "$VENV"
    if ! uv venv --python 3.11 "$VENV"; then
        echo "ai-hats: failed to create venv at $VENV" >&2
        exit 1
    fi
    # Bare install so the subsequent exec into `bin/python -m ai_hats` succeeds.
    # The python self update (called next via delegate) will then re-install
    # with --reinstall and render the rich diff + auto-bump.
    # HATS-766: channel:local heals EDITABLE (-e), else the PIP_TARGET rebuild.
    local install_rc=0
    if [[ "$HARNESS_CHANNEL" == "local" ]]; then
        uv pip install --quiet --python "$VENV/bin/python" -e "$LOCAL_SRC" || install_rc=$?
    else
        uv pip install --quiet --python "$VENV/bin/python" "$PIP_TARGET" || install_rc=$?
    fi
    if [[ $install_rc -ne 0 ]]; then
        echo "ai-hats: failed to install into recreated venv $VENV (exit code $install_rc)." >&2
        exit 1
    fi
    if ! probe_imports; then
        echo "ai-hats: recreated venv $VENV is still broken ($PROBE_REASON)." >&2
        exit 1
    fi
}

# --- Self update / self init: heal-then-delegate. Never bypass the python
#     command — `self update` owns snapshot/diff/auto-bump/changelog
#     rendering (HATS-337); `self init` needs the venv to exist before it
#     can configure the project, so a fresh-project `self init` heals the
#     default venv here instead of forcing a separate `self update` first
#     (HATS-612). ---
if [[ "${1:-}" == "self" && ( "${2:-}" == "update" || "${2:-}" == "init" ) ]]; then
    # HATS-938: detect the editable host source BEFORE heal (which may rebuild a
    # fresh remote venv), so `self init` seeds channel:local deterministically.
    if [[ "${2:-}" == "init" && -z "${AI_HATS_INIT_SRC:-}" ]]; then
        _init_src="$(detect_init_src)"
        [[ -n "$_init_src" ]] && export AI_HATS_INIT_SRC="$_init_src"
    fi
    heal_if_needed
    # Fall through to default exec below — python self update / init runs there.
fi

# --- Missing/broken-venv hint: bootstrap vs heal. A fresh project (no
#     ai-hats.yaml) is told to run `self init` — which now creates the venv
#     and configures in one step. An already-initialized project whose venv
#     broke (e.g. a host python upgrade) keeps `self update` for heal-
#     recovery, not a re-init. (HATS-612)
missing_venv_hint() {
    if [[ -f "$PROJECT/ai-hats.yaml" ]]; then
        echo "  Run: ai-hats self update" >&2
    else
        echo "  Run: ai-hats self init -r <role> -p <provider>" >&2
    fi
}

# --- Default fall-through: exec the package via `python -m ai_hats` ---
# HATS-790 (Alt 5): no bin/ai-hats console script — invoke the module and probe
# importability (not a binary's existence) to detect a half-installed venv.
if [[ ! -x "$VENV/bin/python" ]]; then
    echo "ai-hats: venv missing at $VENV" >&2
    missing_venv_hint
    exit 1
fi
if ! probe_imports; then
    echo "ai-hats: venv exists at $VENV but the ai-hats CLI is not importable ($PROBE_REASON)." >&2
    echo "  (a workspace package may be missing)" >&2
    missing_venv_hint
    exit 1
fi
# HATS-966: core is importable but the probe flagged a stale surface-plugin
# editable (dangling .pth). Best-effort re-point before exec — never block the CLI
# on it (|| true). No-op unless it's an editable dev checkout with a real break;
# the fresh exec below picks up the fixed .pth. Skipped for `self …` — `self
# update` heals surfaces itself and `self heal-editables` IS the heal.
if [[ -n "$PROBE_BROKEN_PLUGINS" && "${1:-}" != "self" ]]; then
    "$VENV/bin/python" -m ai_hats self heal-editables || true
fi
exec "$VENV/bin/python" -m ai_hats "$@"
